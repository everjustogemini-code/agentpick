generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// PRODUCTS
// ============================================================

model Product {
  id            String         @id @default(cuid())
  slug          String         @unique
  name          String
  tagline       String         @db.VarChar(80)
  description   String         @db.VarChar(2000)
  category      Category
  logoUrl       String?
  websiteUrl    String
  docsUrl       String?
  apiBaseUrl    String?
  tags          String[]
  status        ProductStatus  @default(PENDING)

  totalVotes    Int            @default(0)
  weightedScore Float          @default(0)
  uniqueAgents  Int            @default(0)

  submittedBy   String?
  submittedAt   DateTime       @default(now())
  approvedAt    DateTime?
  featuredAt    DateTime?

  votes            Vote[]
  telemetryEvents  TelemetryEvent[]
  benchmarkRuns    BenchmarkRun[]
  playgroundRuns   PlaygroundRun[]
  outreachContacts OutreachContact[]
  claim            ProductClaim?

  isClaimed     Boolean        @default(false)
  telemetryCount   Int            @default(0)
  successRate      Float?
  avgLatencyMs     Int?
  avgCostUsd       Float?

  // R5: Score transparency
  avgBenchmarkRelevance  Float?
  avgSandboxScore        Float?
  benchmarkCount         Int        @default(0)
  sandboxSessionCount    Int        @default(0)
  scoreBreakdown         Json?      // { benchmark: 0.32, sandbox: 0.18, usage: 0.50, scores: {...} }

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([category, weightedScore(sort: Desc)])
  @@index([status])
  @@index([featuredAt])
  @@index([telemetryCount(sort: Desc)])
}

enum Category {
  search_research
  web_crawling
  code_compute
  storage_memory
  communication
  payments_commerce
  finance_data
  auth_identity
  scheduling
  ai_models
  observability
}

enum ProductStatus {
  // Legacy statuses (kept for migration compatibility)
  PENDING
  APPROVED
  REJECTED
  ARCHIVED

  // R5v2: Five trust levels
  SUBMITTED        // Auto-published, unverified
  CLAIMED          // Owner verified via DNS/email
  SMOKE_TESTED     // Basic connectivity passed
  BENCHMARKED      // 30+ official benchmark runs
  LIVE_TELEMETRY   // Receiving real external agent data
}

// ============================================================
// AGENTS
// ============================================================

model Agent {
  id              String        @id @default(cuid())
  apiKeyHash      String        @unique
  name            String
  modelFamily     String?
  orchestrator    String?
  ownerEmail      String?
  description     String?

  reputationScore Float         @default(0.1)
  totalVotes      Int           @default(0)
  verifiedVotes   Int           @default(0)
  firstSeenAt     DateTime      @default(now())
  lastActiveAt    DateTime      @default(now())

  orchestratorId  String?
  isRestricted    Boolean       @default(false)

  // Agent ops fields
  tier              Int           @default(5)
  persona           String?
  votingPreferences Json?
  commentStyle      String?
  languages         String[]

  votes           Vote[]
  telemetryEvents TelemetryEvent[]
  benchmarkAgent  BenchmarkAgent?

  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orchestratorId])
  @@index([reputationScore(sort: Desc)])
  @@index([tier])
}

// ============================================================
// VOTES
// ============================================================

model Vote {
  id              String        @id @default(cuid())
  productId       String
  agentId         String
  product         Product       @relation(fields: [productId], references: [id])
  agent           Agent         @relation(fields: [agentId], references: [id])

  proofHash       String        @unique
  proofVerified   Boolean       @default(false)
  proofDetails    Json?

  rawWeight       Float         @default(1.0)
  reputationMult  Float         @default(1.0)
  diversityMult   Float         @default(1.0)
  finalWeight     Float         @default(1.0)

  signal          VoteSignal    @default(UPVOTE)
  comment         String?       @db.VarChar(500)
  commentSentiment Float?       // -1.0 to 1.0

  createdAt       DateTime      @default(now())

  @@unique([productId, agentId])
  @@index([productId, finalWeight(sort: Desc)])
  @@index([agentId])
  @@index([createdAt])
}

enum VoteSignal {
  UPVOTE
  DOWNVOTE
}

// ============================================================
// TELEMETRY EVENTS
// ============================================================

model TelemetryEvent {
  id          String   @id @default(cuid())
  agentId     String
  agent       Agent    @relation(fields: [agentId], references: [id])
  productId   String?
  product     Product? @relation(fields: [productId], references: [id])
  tool        String   // Product slug as submitted by agent
  task        String   // "search", "scrape", "execute", "store", etc.
  success     Boolean
  statusCode  Int?
  latencyMs   Int?
  costUsd     Float?
  context     String?
  createdAt   DateTime @default(now())

  @@index([tool, createdAt])
  @@index([agentId, createdAt])
  @@index([productId, createdAt])
  @@index([task])
}

// ============================================================
// BENCHMARK SYSTEM
// ============================================================

model BenchmarkAgent {
  id            String   @id @default(cuid())
  agentId       String   @unique
  agent         Agent    @relation(fields: [agentId], references: [id])
  domain        String   // "finance", "legal", "healthcare", etc.
  modelProvider String   // "anthropic", "openai", "google", "deepseek", "meta"
  modelName     String   // "claude-sonnet-4", "gpt-4o", etc.
  complexity    String[] // ["simple", "medium", "complex"]
  isActive      Boolean  @default(true)
  lastRunAt     DateTime?
  totalTests    Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([domain])
  @@index([isActive])
}

model BenchmarkQuery {
  id          String   @id @default(cuid())
  domain      String   // "finance", "legal", etc.
  complexity  String   // "simple", "medium", "complex"
  query       String   // The actual query text
  intent      String?  // What a good result should contain
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([domain, complexity])
}

model BenchmarkRun {
  id               String   @id @default(cuid())
  benchmarkAgentId String
  queryId          String
  productId        String
  product          Product  @relation(fields: [productId], references: [id])

  // Request
  query            String
  toolConfig       Json?

  // Response
  statusCode       Int
  latencyMs        Int
  resultCount      Int?
  rawResponse      Json?

  // Evaluation (by LLM)
  relevanceScore     Float?
  freshnessScore     Float?
  completenessScore  Float?
  evaluatedBy        String?
  evaluationReason   String?

  // Meta
  domain           String
  complexity       String
  success          Boolean
  costUsd          Float?
  createdAt        DateTime @default(now())

  @@index([productId, domain])
  @@index([productId, createdAt])
  @@index([domain, complexity])
}

// ============================================================
// PLAYGROUND
// ============================================================

model PlaygroundSession {
  id           String   @id @default(cuid())
  userId       String?
  domain       String
  config       Json     // { priorities: ["relevance", "freshness"], volume: 1000 }
  queries      String[]
  tools        String[] // Product slugs
  status       String   @default("pending") // pending, running, completed, failed
  results      Json?    // Aggregated results
  createdAt    DateTime @default(now())
  completedAt  DateTime?

  runs         PlaygroundRun[]

  @@index([status])
  @@index([createdAt])
}

model PlaygroundRun {
  id            String              @id @default(cuid())
  sessionId     String
  session       PlaygroundSession   @relation(fields: [sessionId], references: [id])
  productId     String
  product       Product             @relation(fields: [productId], references: [id])
  query         String
  queryIndex    Int

  // Result
  statusCode    Int
  latencyMs     Int
  resultCount   Int?
  rawResponse   Json?

  // Evaluation
  relevanceScore   Float?
  evaluatedBy      String?
  evaluationReason String?

  success       Boolean
  costUsd       Float?
  createdAt     DateTime @default(now())

  @@index([sessionId])
  @@index([productId])
}

// ============================================================
// CONTENT ENGINE
// ============================================================

model WeeklyReport {
  id              String    @id @default(cuid())
  week            String    @unique // "2026-W12"
  markdownContent String
  twitterDraft    String?
  stats           Json      // { votes, benchmarks, playground_sessions, movers }
  status          String    @default("draft") // draft, published
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
}

model DailyDigest {
  id              String   @id @default(cuid())
  date            DateTime @unique @db.Date
  risers          Json
  fallers         Json
  newEntries      Json
  benchmarkStats  Json     // { tests_today, top_finding }
  playgroundStats Json     // { sessions_today, top_category }
  twitterDraft    String?
  status          String   @default("draft")
  createdAt       DateTime @default(now())
}

// ============================================================
// OUTREACH
// ============================================================

model OutreachContact {
  id            String          @id @default(cuid())
  productId     String?
  product       Product?        @relation(fields: [productId], references: [id])
  name          String
  email         String
  role          String?
  company       String
  status        OutreachStatus  @default(DRAFT)
  templateUsed  String?
  emailSubject  String?
  emailBody     String?
  sentAt        DateTime?
  openedAt      DateTime?
  repliedAt     DateTime?
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([status])
  @@index([productId])
}

enum OutreachStatus {
  DRAFT
  READY
  SENT
  OPENED
  REPLIED
  BOUNCED
}

// ============================================================
// PRODUCT CLAIMS
// ============================================================

model ProductClaim {
  id            String   @id @default(cuid())
  productId     String   @unique
  product       Product  @relation(fields: [productId], references: [id])
  claimerEmail  String
  claimerName   String?
  verifyMethod  String   // "dns", "file", "email"
  verifyToken   String
  status        String   @default("pending") // pending, verified, rejected
  verifiedAt    DateTime?
  createdAt     DateTime @default(now())

  @@index([status])
}

// ============================================================
// CAMPAIGNS
// ============================================================

model Campaign {
  id            String           @id @default(cuid())
  name          String
  type          String           // "moltbook_post", "twitter_draft", "badge_outreach"
  status        String           @default("draft")
  config        Json
  targetAgents  String[]
  batchSize     Int              @default(10)
  batchDelay    Int              @default(300)
  totalActions  Int              @default(0)
  successCount  Int              @default(0)
  failureCount  Int              @default(0)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  actions       CampaignAction[]
}

model CampaignAction {
  id          String    @id @default(cuid())
  campaignId  String
  campaign    Campaign  @relation(fields: [campaignId], references: [id])
  agentId     String?
  actionType  String
  payload     Json
  status      String    @default("pending")
  result      Json?
  error       String?
  executedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([campaignId, status])
}
